Bootstrap: localimage
From: raser-2.3.sif

%environment
    export LC_ALL=C
    export LANG=C

    # External ROOT / Geant4 provided by host
    export ROOTSYS=${ROOTSYS:-/opt/root}
    export GEANT4_DIR=${GEANT4_DIR:-/opt/geant4}

    export PATH=$ROOTSYS/bin:$GEANT4_DIR/bin:$PATH
    export LD_LIBRARY_PATH=$ROOTSYS/lib:$ROOTSYS/lib64:$GEANT4_DIR/lib:$GEANT4_DIR/lib64:$LD_LIBRARY_PATH

    # Headless plotting for batch/server environments
    export MPLBACKEND=${MPLBACKEND:-Agg}

%post
    set -e

    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        git \
        wget \
        curl \
        vim \
        ca-certificates \
        pkg-config \
        ngspice \
        libboost-all-dev \
        libice6 \
        libsm6 \
        libxext6 \
        libxrender1 \
        libglib2.0-0 \
        libgl1 \
        libegl1 \
        libx11-dev \
        libxpm-dev \
        libxft-dev \
        libxext-dev \
        libgif-dev \
        libxrender-dev \
        libxmu-dev \
        libssl-dev \
        zlib1g-dev \
        libbz2-dev \
        libreadline-dev \
        libsqlite3-dev \
        libncursesw5-dev \
        xz-utils \
        tk-dev \
        libxml2-dev \
        libxmlsec1-dev \
        libffi-dev \
        liblzma-dev \
        uuid-dev

    # Keep system python available, but core workflow uses project-managed Python 3.10
    apt-get install -y --no-install-recommends \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        python3-setuptools \
        python3-wheel

    ln -sf /usr/bin/python3 /usr/bin/python

    python3 -m pip install --upgrade pip setuptools wheel

    # Core Python runtime packages
    pip install \
        numpy \
        scipy \
        pandas \
        matplotlib \
        h5py \
        PyYAML \
        tqdm \
        numba \
        joblib \
        pylandau \
        gmsh \
        psutil

    # Simulation/runtime packages
    pip install mkl
    pip install devsim
    pip install geant4-pybind

%runscript
    exec /bin/bash "$@"
